#!/usr/bin/env bash
#
# Pre-push hook: runs regression tests and formatting checks
# before allowing push to remote.
#
# Enforced (blocks push on failure):
#   - make test-fast   (pytest suite, parallel-safe + serial stages)
#   - make format-check (black formatting)
#   - make lint        (flake8)
#   - make type-check  (mypy)
#
# Bypass (emergency only): git push --no-verify
#

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'

echo -e "${YELLOW}=== Pre-push checks ===${NC}"

# Change to repository root
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Activate virtual environment if available
if [ -f "mcp_env/bin/activate" ]; then
    # shellcheck disable=SC1091
    . mcp_env/bin/activate
elif [ -f "mcp_env/Scripts/activate" ]; then
    # shellcheck disable=SC1091
    . mcp_env/Scripts/activate
fi

# Skip checks when pushing only ref deletions. Git passes each proposed ref on
# stdin as: <local_ref> <local_sha1> <remote_ref> <remote_sha1>. For deletions,
# <local_ref> is the literal string "(delete)".
delete_count=0
ref_count=0
while read -r local_ref _ _ _; do
    ref_count=$((ref_count + 1))
    if [ "$local_ref" = "(delete)" ]; then
        delete_count=$((delete_count + 1))
    fi
done

if [ "$ref_count" -gt 0 ] && [ "$ref_count" -eq "$delete_count" ]; then
    echo -e "${GREEN}Push only deletes remote refs; skipping pre-push checks.${NC}"
    exit 0
fi

# Check that pytest is available
if ! python3 -m pytest --version >/dev/null 2>&1; then
    echo -e "${RED}ERROR: pytest not found. Install dev dependencies:${NC}"
    echo "  pip install .[dev]"
    echo "  # or: make install-dev"
    exit 1
fi

# === ENFORCED CHECKS (block push on failure) ===

# Run tests
echo -e "${YELLOW}Running tests (make test-fast)...${NC}"
if make test-fast; then
    echo -e "${GREEN}Tests passed!${NC}"
else
    echo -e "${RED}Tests FAILED. Push aborted.${NC}"
    echo "Fix the failing tests and try again."
    exit 1
fi

# Run formatting check
echo -e "${YELLOW}Running format check (make format-check)...${NC}"
if make format-check; then
    echo -e "${GREEN}Format check passed!${NC}"
else
    echo -e "${RED}Format check FAILED. Push aborted.${NC}"
    echo "Run 'make format' to fix formatting, then re-commit."
    exit 1
fi

# Run lint check
echo -e "${YELLOW}Running lint (make lint)...${NC}"
if make lint; then
    echo -e "${GREEN}Lint passed!${NC}"
else
    echo -e "${RED}Lint FAILED. Push aborted.${NC}"
    echo "Fix the lint errors and try again."
    exit 1
fi

# Run type check
echo -e "${YELLOW}Running type check (make type-check)...${NC}"
if make type-check; then
    echo -e "${GREEN}Type check passed!${NC}"
else
    echo -e "${RED}Type check FAILED. Push aborted.${NC}"
    echo "Fix the type errors and try again."
    exit 1
fi

echo -e "${GREEN}=== All pre-push checks passed ===${NC}"
